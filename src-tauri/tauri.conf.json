{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simple TODO",
  "version": "0.2.0",
  "identifier": "com.tatechon.simpletodo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Simple TODO",
        "width": 960,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwNjlGODk5OUJDNzkzQjIKUldTeWs4ZWJtZmhwWUhYL2FTVFpaN1FGK1ZTWmRiaENSZmxOZUhEYzNrZHd3M1pEN0lDVzNWY0EK",
      "endpoints": [
        "https://github.com/ktateishi/simple-todo-desktop/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
